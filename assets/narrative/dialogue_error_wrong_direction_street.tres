[gd_resource type="Resource" script_class="NarrativeSequence" load_steps=8 format=3]

[ext_resource type="Script" path="res://scripts/core/NarrativeSequence.gd" id="1_sequence"]
[ext_resource type="Script" path="res://scripts/core/NarrativeLine.gd" id="2_line"]

[sub_resource type="Resource" id="NarrativeLine_1"]
script = ExtResource("2_line")
speaker_id = &""
speaker_name = "晓明"
text = "不对，这边风声不一样，走偏了。"
duration = 2.8

[sub_resource type="Resource" id="NarrativeLine_2"]
script = ExtResource("2_line")
speaker_id = &""
speaker_name = "晓明"
text = "杖碰到墙了……这不是超市入口，退回去。"
duration = 3.1

[sub_resource type="Resource" id="NarrativeLine_3"]
script = ExtResource("2_line")
speaker_id = &""
speaker_name = "晓明"
text = "不确定了，问一下。——请问，惠民超市怎么走？"
duration = 3.4

[sub_resource type="Resource" id="NarrativeLine_4"]
script = ExtResource("2_line")
speaker_id = &""
speaker_name = "路人"
text = "惠民超市啊，你往前走，过了路口左转，门口有个台阶的那个就是。"
duration = 4.0

[sub_resource type="Resource" id="NarrativeLine_5"]
script = ExtResource("2_line")
speaker_id = &""
speaker_name = "晓明"
text = "谢谢您。"
duration = 1.9

[resource]
script = ExtResource("1_sequence")
sequence_id = &"error_wrong_direction_street"
lines = [SubResource("NarrativeLine_1"), SubResource("NarrativeLine_2"), SubResource("NarrativeLine_3"), SubResource("NarrativeLine_4"), SubResource("NarrativeLine_5")]
lock_input = true
lock_gameplay = true
default_line_duration = 3.0
