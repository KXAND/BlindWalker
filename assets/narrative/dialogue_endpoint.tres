[gd_resource type="Resource" script_class="NarrativeSequence" format=3 uid="uid://b8xq7l3kpw2na"]

[ext_resource type="Script" uid="uid://c68wt0narrseq" path="res://scripts/core/NarrativeSequence.gd" id="1_sequence"]
[ext_resource type="Script" uid="uid://cjk6emp8lxq0m" path="res://scripts/core/NarrativeLine.gd" id="2_line"]

[sub_resource type="Resource" id="NarrativeLine_1"]
script = ExtResource("2_line")
speaker_name = "晓明"
text = "就是这家店了。"
duration = 100.0

[sub_resource type="Resource" id="NarrativeLine_2"]
script = ExtResource("2_line")
text = "晓明走进店里，摸索着找到白糖的货架，拿了一袋白糖去结账。"
duration = 100.0

[sub_resource type="Resource" id="NarrativeLine_3"]
script = ExtResource("2_line")
text = "此时一个熟悉的声音在身后响起"
duration = 100.0

[sub_resource type="Resource" id="NarrativeLine_4"]
script = ExtResource("2_line")
speaker_name = "王叔"
text = "晓明？"
duration = 100.0

[sub_resource type="Resource" id="NarrativeLine_5"]
script = ExtResource("2_line")
speaker_name = "晓明"
text = "王叔？你怎么来了？"
duration = 100.0

[sub_resource type="Resource" id="NarrativeLine_6"]
script = ExtResource("2_line")
speaker_name = "王叔"
text = "晓明，你怎么跑这么远来了？"
duration = 100.0

[sub_resource type="Resource" id="NarrativeLine_7"]
script = ExtResource("2_line")
speaker_name = "晓明"
text = "李奶奶腿脚不方便，托我帮她买一袋白糖。楼下的小卖部关门了，我就找到这边来了。"
duration = 100.0

[sub_resource type="Resource" id="NarrativeLine_8"]
script = ExtResource("2_line")
speaker_name = "王叔"
text = "我刚好也顺路买东西回去，我载你回去吧。"
duration = 100.0

[resource]
script = ExtResource("1_sequence")
sequence_id = &"endpoint"
lines = [SubResource("NarrativeLine_1"), SubResource("NarrativeLine_2"), SubResource("NarrativeLine_3"), SubResource("NarrativeLine_4"), SubResource("NarrativeLine_5"), SubResource("NarrativeLine_6"), SubResource("NarrativeLine_7"), SubResource("NarrativeLine_8")]
default_line_duration = 3.0
