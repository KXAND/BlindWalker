[gd_resource type="Resource" script_class="NarrativeSequence" load_steps=6 format=3]

[ext_resource type="Script" path="res://scripts/core/NarrativeSequence.gd" id="1_sequence"]
[ext_resource type="Script" path="res://scripts/core/NarrativeLine.gd" id="2_line"]

[sub_resource type="Resource" id="NarrativeLine_1"]
script = ExtResource("2_line")
speaker_id = &"xiaoming"
speaker_name = "晓明"
text = "李奶奶，我正好要下楼扔垃圾，您有什么要带的吗？"
audio_id = &"ui_click"
duration = 3.0

[sub_resource type="Resource" id="NarrativeLine_2"]
script = ExtResource("2_line")
speaker_id = &"li_grandma"
speaker_name = "李奶奶"
text = "晓明啊，能不能顺路帮我去小区门口的小超市买一包白糖？"
duration = 3.2

[sub_resource type="Resource" id="NarrativeLine_3"]
script = ExtResource("2_line")
speaker_id = &""
speaker_name = ""
text = "任务更新：前往小区门口的小超市，买一包白糖。"
duration = 2.6

[resource]
script = ExtResource("1_sequence")
sequence_id = &"sample_neighbor_request"
lines = [SubResource("NarrativeLine_1"), SubResource("NarrativeLine_2"), SubResource("NarrativeLine_3")]
lock_input = true
lock_gameplay = true
default_line_duration = 3.0
