[gd_resource type="Resource" script_class="NarrativeSequence" load_steps=7 format=3]

[ext_resource type="Script" path="res://scripts/core/NarrativeSequence.gd" id="1_sequence"]
[ext_resource type="Script" path="res://scripts/core/NarrativeLine.gd" id="2_line"]

[sub_resource type="Resource" id="NarrativeLine_1"]
script = ExtResource("2_line")
speaker_id = &""
speaker_name = "晓明"
text = "这边是冰柜，太冷了，调料区不在这。"
duration = 3.0

[sub_resource type="Resource" id="NarrativeLine_2"]
script = ExtResource("2_line")
speaker_id = &""
speaker_name = "晓明"
text = "找了半天没找到，问一下。——您好，海天生抽在哪边？"
duration = 3.6

[sub_resource type="Resource" id="NarrativeLine_3"]
script = ExtResource("2_line")
speaker_id = &""
speaker_name = "店员"
text = "调料在第二排，靠里面那头。"
duration = 2.6

[sub_resource type="Resource" id="NarrativeLine_4"]
script = ExtResource("2_line")
speaker_id = &""
speaker_name = "晓明"
text = "好，谢谢。"
duration = 2.0

[resource]
script = ExtResource("1_sequence")
sequence_id = &"error_wrong_direction_supermarket"
lines = [SubResource("NarrativeLine_1"), SubResource("NarrativeLine_2"), SubResource("NarrativeLine_3"), SubResource("NarrativeLine_4")]
lock_input = true
lock_gameplay = true
default_line_duration = 3.0
