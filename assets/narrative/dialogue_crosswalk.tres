[gd_resource type="Resource" script_class="NarrativeSequence" format=3 uid="uid://dn6uxb83hj37h"]

[ext_resource type="Script" uid="uid://c68wt0narrseq" path="res://scripts/core/NarrativeSequence.gd" id="1_sequence"]
[ext_resource type="Script" uid="uid://cjk6emp8lxq0m" path="res://scripts/core/NarrativeLine.gd" id="2_line"]

[sub_resource type="Resource" id="NarrativeLine_1"]
script = ExtResource("2_line")
speaker_name = "晓明"
text = "该过马路了，慢慢走吧。"
duration = 100.0

[sub_resource type="Resource" id="NarrativeLine_2"]
script = ExtResource("2_line")
speaker_name = "晓明"
text = "这个马路路口没有提示音，小心一点。"
duration = 100.0

[sub_resource type="Resource" id="NarrativeLine_3"]
script = ExtResource("2_line")
speaker_name = "晓明"
text = "好像没有车了。"
duration = 100.0

[sub_resource type="Resource" id="NarrativeLine_4"]
script = ExtResource("2_line")
speaker_name = "好心路人"
text = "同学您好，您是要过马路吗？要帮帮忙吗？"
duration = 100.0

[sub_resource type="Resource" id="NarrativeLine_5"]
script = ExtResource("2_line")
speaker_name = "晓明"
text = "不用了，我想尝试一下自己过马路，谢谢你的好意。"
duration = 100.0

[sub_resource type="Resource" id="NarrativeLine_6"]
script = ExtResource("2_line")
speaker_name = "好心路人"
text = "哦，好的好的，那您小心一点。"
duration = 100.0

[resource]
script = ExtResource("1_sequence")
sequence_id = &"crosswalk"
lines = [SubResource("NarrativeLine_1"), SubResource("NarrativeLine_2"), SubResource("NarrativeLine_3"), SubResource("NarrativeLine_4"), SubResource("NarrativeLine_5"), SubResource("NarrativeLine_6")]
default_line_duration = 3.0
